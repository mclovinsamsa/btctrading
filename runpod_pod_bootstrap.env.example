# Exemple de configuration pour un nouveau pod RunPod
# Usage:
#   cp runpod_pod_bootstrap.env.example .runpod_bootstrap.env
#   source .runpod_bootstrap.env
#   bash runpod_pod_bootstrap.sh

export REPO_URL="https://github.com/mclovinsamsa/btctrading.git"
export REPO_BRANCH="main"

# Dossier de travail sur le pod
export WORKSPACE_DIR="/workspace"
export PROJECT_DIR="/workspace/btctrading"
export VENV_DIR="/workspace/btctrading/venv"

# Installer les paquets système via apt-get
export INSTALL_SYSTEM_DEPS="1"

# Configure Jupyter Lab pour RunPod
export SETUP_JUPYTER="1"
export JUPYTER_PORT="8888"
export JUPYTER_TOKEN=""

# Prépare les données du projet automatiquement
export PREPARE_DATA="1"

# Archives optionnelles à récupérer automatiquement
export MODEL_ARCHIVE_URL=""
export DATA_ARCHIVE_URL=""

# Dépendances Python additionnelles éventuelles
export EXTRA_PIP_PACKAGES=""

# Optionnel: index Torch spécifique
# CPU:
# export TORCH_INDEX_URL="https://download.pytorch.org/whl/cpu"
# CUDA 12.8:
# export TORCH_INDEX_URL="https://download.pytorch.org/whl/cu128"
export TORCH_VERSION="2.8.0"
export TORCH_INDEX_URL=""
export SKIP_TORCH_INSTALL="0"

# Parametres du helper final_validation
export FINAL_VALIDATION_DEVICE="cuda"
export FINAL_VALIDATION_HOLDOUT_RATIO="0.2"
export FINAL_VALIDATION_FEE="0.0004"
export FINAL_VALIDATION_SLIPPAGE="0.0008"
export FINAL_VALIDATION_WF_WINDOWS="4"

# Commande exécutée en fin de bootstrap
export POST_SETUP_COMMAND=""
