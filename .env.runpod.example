# RunPod Environment Configuration
# Copy this to .env.runpod and fill in your values

# Your RunPod API Key
# Get it from: https://www.runpod.io/console/api-keys
RUNPOD_API_KEY=your_api_key_here

# Docker Registry credentials
DOCKER_USERNAME=your_docker_username
DOCKER_PASSWORD=your_docker_password
CONTAINER_IMAGE=yourusername/btc-xgb-poc:latest

# Pod configuration
POD_NAME=btc-xgb-poc
GPU_COUNT=1
GPU_TYPE=RTX_4090
CONTAINER_DISK=20
VOLUME_SIZE=10

# Optional: Jupyter security
JUPYTER_TOKEN=your_token_here
JUPYTER_PASSWORD=your_password_here

# Optional: SSH configuration
ENABLE_SSH=false
SSH_KEY_PATH=~/.ssh/id_rsa.pub
